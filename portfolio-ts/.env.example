# Portfolio environment variables
# Copy to .env and fill in real values. Never commit .env to version control.

# PostgreSQL connection string (required)
PORTFOLIO_DB_URL=postgresql://portfolio_user:password@localhost:5432/portfolio

# API CORS origin — set to the dashboard URL or ChatGPT connector origin to enable CORS
# PORTFOLIO_API_CORS_ORIGIN=https://dashboard.example.com

# Benchmark ticker fallback (default: SPY)
# PORTFOLIO_BENCHMARK_TICKERS=SPY

# S3 backup credentials (optional, for `portfolio backup`)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# PORTFOLIO_BACKUP_BUCKET=my-portfolio-backups

# tunnel-client placeholders (for OpenAI secure MCP tunnel — real values go in tunnel-client profile, not here)
# TUNNEL_ID=tunnel_0123456789abcdef0123456789abcdef
# OPENAI_API_KEY=sk-...   (use tunnel-client runtime key, not env var)
