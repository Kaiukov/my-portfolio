# Portfolio CLI environment configuration (TypeScript / Bun)
# Copy to .env (gitignored) and adjust values.
# The CLI auto-loads this file from the current working directory or any parent
# directory before reading PORTFOLIO_DB_URL, so `export` is usually not required.

# --- Active ----------------------------------------------------------------
# PostgreSQL connection string (local Postgres or hosted: Supabase, Neon, etc.)
PORTFOLIO_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Benchmark tickers used by `portfolio performance` (comma-separated).
# First ticker is used as the default benchmark; falls back to SPY.
PORTFOLIO_BENCHMARK_TICKERS=SPY

# --- Reserved / legacy (read by the old Python CLI, ignored by the TS CLI) --
# The TypeScript CLI uses the `yahoo-finance2` npm package directly; the
# `provider` knob is not honored. Kept here for downstream tooling that still
# inspects the variable.
PORTFOLIO_PRICE_PROVIDER=yfinance

# Path for the legacy Python `portfolio_db.logger` JSON log file. The
# TypeScript CLI does not write to this path; remove once no caller depends on it.
PORTFOLIO_LOG_PATH=logs/portfolio.log

## Service mode (#135)
# PostgreSQL connection string for the Dockerized long-lived service.
PORTFOLIO_DB_URL=postgresql://portfolio_user:[YOUR-PASSWORD]@db.example.com:5432/portfolio

# API listen port. `PORT` takes precedence when both are set.
PORT=8787
PORTFOLIO_API_PORT=8787

# Optional CORS origin for the API (useful when frontends are served from a separate domain).
PORTFOLIO_API_CORS_ORIGIN=https://dashboard.example.com

# In-process refresh scheduler interval.
PORTFOLIO_REFRESH_INTERVAL=1h

# Enable the S3/R2 backup job (defaults to false).
PORTFOLIO_BACKUP_ENABLED=false

# Backup job interval when enabled (defaults to 24h).
PORTFOLIO_BACKUP_INTERVAL=24h

# Enable Cloudflare KV publishing jobs (defaults to false).
PORTFOLIO_CLOUDFLARE_PUBLISH=false

# Cloudflare publish job interval when publishing is enabled.
PORTFOLIO_PUBLISH_INTERVAL=1h

# Run `portfolio init` automatically on boot.
PORTFOLIO_INIT_ON_BOOT=false
