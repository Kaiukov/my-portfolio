# Portfolio CLI environment configuration
# Copy to .env and adjust values

# PostgreSQL connection string (Supabase or local Postgres)
PORTFOLIO_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Path for structured JSON logs (default: logs/portfolio.log)
PORTFOLIO_LOG_PATH=logs/portfolio.log

# Price data provider (only yfinance is supported; reserved for future providers)
PORTFOLIO_PRICE_PROVIDER=yfinance

# Benchmark tickers for performance comparison (comma-separated, default: SPY)
PORTFOLIO_BENCHMARK_TICKERS=SPY
